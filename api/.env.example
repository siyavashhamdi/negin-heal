# Application Configuration
BASE_URL=http://localhost:4000
APP_URL=http://localhost:8080
PORT=4000
# Production example:
# BASE_URL=https://neginheal.ir
# APP_URL=https://neginheal.ir
# PORT=5701
API_PREFIX=api/v1
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=negin-heal

# JWT Configuration
JWT_SECRET=6KFkxssr44whVwz4emOQiNcp5gGxuKBPYvoQRWlruaX
JWT_EXPIRES_IN=24h

# Captcha Configuration
CAPTCHA_ENABLED=true
CAPTCHA_TTL_SECONDS=120
CAPTCHA_MAX_ATTEMPTS=5

# Logging Configuration
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# Max HTTP request body size in bytes (default 50MB; applies to file uploads and JSON payloads)
# MAX_REQUEST_SIZE=52428800

# GraphQL Configuration
GRAPHQL_PLAYGROUND=true
GRAPHQL_INTROSPECTION=true

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
# VAPID_SUBJECT should be a mailto: or https: contact URI for your app.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@neginheal.ir

# MinIO Configuration
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=your-minio-root-password
MINIO_BUCKET=negin-heal

# Remote dev option: you can use the Console URL; backend maps it to S3 API automatically.
# MINIO_ENDPOINT=https://minio.neginheal.ir
# MINIO_PORT=443
# MINIO_USE_SSL=true
