# Application Configuration
BASE_URL=http://localhost:4000
APP_URL=http://localhost:8080
PORT=4000
API_PREFIX=api/v1
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=negin-heal

# JWT Configuration
JWT_SECRET=6KFkxssr44whVwz4emOQiNcp5gGxuKBPYvoQRWlruaX
JWT_EXPIRES_IN=24h

# Captcha Configuration
CAPTCHA_ENABLED=true
CAPTCHA_TTL_SECONDS=120
CAPTCHA_MAX_ATTEMPTS=5

# Logging Configuration
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# Max HTTP request body size in bytes (default ~68MB; supports 50MB file uploads as base64)
# MAX_REQUEST_SIZE=71303168

# GraphQL Configuration
GRAPHQL_PLAYGROUND=true
GRAPHQL_INTROSPECTION=true

# MinIO Configuration
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin
MINIO_BUCKET=negin-heal
