# Application Configuration
VITE_PORT=8080
VITE_API_BASE_URL=http://localhost:4000
# Public site URL for canonical links, sitemap, and social previews (no trailing slash).
# Required for production builds so sitemap.xml lists https://neginheal.ir URLs.
VITE_APP_URL=https://neginheal.ir
# Production example:
# VITE_PORT=5700
# VITE_API_BASE_URL=https://neginheal.ir
# VITE_ALLOWED_HOSTS=neginheal.ir,www.neginheal.ir

# Build Metadata
VITE_DEPLOY_HASH=N/A
VITE_DEPLOY_DATE_TIME=2025-01-01, 00:00:00.000

# Others
VITE_EXPOSE_VIA_NETWORK=true # Expose in Network - Use this for test app via network - You would need to port-forward for intenet test
VITE_NODE_ENV=development
VITE_CAPTCHA_ENABLED=true
VITE_UNDER_CONSTRUCTION=false

# Optional Web Push override (otherwise fetched from API pushNotificationConfig query)
# VITE_VAPID_PUBLIC_KEY=
